{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/arithmetic.html",
      "destination": "/arithmetic/",
      "permanent": true
    },
    {
      "source": "/geometric.html",
      "destination": "/geometric/",
      "permanent": true
    },
    {
      "source": "/recursive-sequence-guide.html",
      "destination": "/recursive-sequence-guide/",
      "permanent": true
    },
    {
      "source": "/fibonacci-sequence-guide.html",
      "destination": "/fibonacci-sequence-guide/",
      "permanent": true
    },
    {
      "source": "/sequence-formulas.html",
      "destination": "/sequence-formulas/",
      "permanent": true
    },
    {
      "source": "/arithmetic-sequence-examples.html",
      "destination": "/arithmetic-sequence-examples/",
      "permanent": true
    },
    {
      "source": "/geometric-sequence-examples.html",
      "destination": "/geometric-sequence-examples/",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/about/",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/contact/",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/privacy/",
      "destination": "/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/privacy-policy.html",
      "destination": "/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/terms.html",
      "destination": "/terms/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
